{
  "name": "everything-desktop-search",
  "version": "1.1.0",
  "private": true,
  "description": "A keyboard-first Everything quick launcher for Windows.",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.node.json && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "pinyin-pro": "^3.28.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uiohook-napi": "^1.5.4",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "local.everything.quicklauncher",
    "productName": "Everything Quick Launcher",
    "icon": "assets/icon.ico",
    "portable": {
      "artifactName": "Everything.Quick.Search.1.1.exe"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    }
  }
}
